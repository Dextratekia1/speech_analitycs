FROM docker.io/library/golang:1.22-bookworm AS build
WORKDIR /src
ENV GOFLAGS=-mod=readonly
COPY audio-uploader-go /src
RUN CGO_ENABLED=0 go build -o /out/audio-uploader-go ./cmd/audio-uploader-go

FROM docker.io/library/debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates tzdata && rm -rf /var/lib/apt/lists/*
COPY --from=build /out/audio-uploader-go /usr/local/bin/audio-uploader-go
ENTRYPOINT ["audio-uploader-go"]
