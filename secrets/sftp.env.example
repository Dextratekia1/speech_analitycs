SFTP_HOST=192.168.100.20
SFTP_PORT=22
SFTP_USER=user
SFTP_PASSWORD=REPLACE_ME
SFTP_REMOTE_BASE=/incoming
# OpenSSH authorized_keys format — obtain with: ssh-keyscan -t ed25519 <SFTP_HOST>
# Required for non-dry-run uploads. The uploader fails closed if this is missing or invalid.
SFTP_HOST_KEY=ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAREPLACE_WITH_REAL_SERVER_PUBLIC_KEY sftp-host
