MSSQL_HOST=192.168.100.10
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASSWORD=REPLACE_ME
MSSQL_DATABASE=aval_cob
MSSQL_ENCRYPT=false
# MSSQL_TRUST_CERT: false is the secure default (no certificate trust bypass).
# Set to true only for internal/self-signed MSSQL servers after explicit operational acceptance.
# If MSSQL_ENCRYPT=false, TLS is not negotiated and this variable has no practical effect.
MSSQL_TRUST_CERT=false
