FROM docker.io/library/golang:1.22-bookworm
WORKDIR /app
COPY audio-uploader-go/ ./audio-uploader-go/
WORKDIR /app/audio-uploader-go

# go.sum is not committed to the repo (generated at build time per project convention).
ENV GOFLAGS=-mod=mod
RUN go mod tidy

# Pre-compile test binaries without running any tests.
RUN go test ./... -run TestDoesNotExist

CMD ["go", "test", "./...", "-v"]
