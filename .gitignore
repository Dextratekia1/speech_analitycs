# ── Secrets ──────────────────────────────────────────────────────────────────
# Real credential files must never be committed.
# Only *.env.example files are tracked.
secrets/*.env
!secrets/*.env.example

# ── Runtime artifacts ────────────────────────────────────────────────────────
# shared/runs/ is a large, PII-bearing runtime directory (audio files, matched
# JSON with debtor names/phones/financial data).  It is mounted into containers
# at runtime and must not enter version control.
shared/runs/

# Operational logs written by run_range*.sh scripts.
logs/

# ── Audio files ───────────────────────────────────────────────────────────────
# GSM source files and converted WAV files are binary runtime artifacts.
*.gsm
*.wav

# ── Archives ─────────────────────────────────────────────────────────────────
# ZIP archives may contain credentials or PII snapshots.
*.zip

# ── Build artifacts ───────────────────────────────────────────────────────────
target/
audio-uploader-go/bin/

# ── Editor / tooling directories ─────────────────────────────────────────────
NvChad/

# ── Orchestrator runtime artifacts ────────────────────────────────────────────
# ledger.db is a SQLite database created by `orchestrator run-step --record`.
# outbox/, archive/, governance-archive/ are created at runtime by bridge/governance commands.
# The config files (.orchestrator/*.yaml) and inbox/ ARE tracked in version control.
.orchestrator/ledger.db
.orchestrator/outbox/
.orchestrator/archive/
.orchestrator/governance-archive/

# ── Orchestrator memory layer ─────────────────────────────────────────────────
# .orchestrator-memory/ is created by `orchestrator memory-init` and contains
# a SQLite database (memory.db) with ingested evidence. Runtime artifact only.
.orchestrator-memory/
