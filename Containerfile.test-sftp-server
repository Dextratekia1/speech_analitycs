FROM docker.io/library/golang:1.22-bookworm AS builder
WORKDIR /app
COPY audio-uploader-go/ ./audio-uploader-go/
WORKDIR /app/audio-uploader-go

# go.sum is committed; -mod=readonly ensures the build does not update module files.
ENV GOFLAGS=-mod=readonly

RUN CGO_ENABLED=0 go build -o /test-sftp-server ./cmd/test-sftp-server/

FROM docker.io/library/debian:bookworm-slim
COPY --from=builder /test-sftp-server /usr/local/bin/test-sftp-server

# /run/sftp-setup is bind-mounted from the host by start_test_sftp.sh.
# The server writes its synthetic env file to /run/sftp-setup/sftp.env on startup.
VOLUME ["/run/sftp-setup"]

ENTRYPOINT ["/usr/local/bin/test-sftp-server"]
